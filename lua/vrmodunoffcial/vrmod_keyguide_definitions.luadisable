    local wep = ply:GetActiveWeapon()
    if not IsValid(wep) then return false end
    return wep:GetClass() == "gmod_tool"
end, {
    { button = "Trigger R", action = "Use Tool" },
    { button = "Trigger L", action = "Alt Fire" },
    { button = "Grip R", action = "Select Mode" },
}, 10)
